<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_card"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/cfg_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_card_pressed"
        android:gravity="center"
        android:padding="8dp"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <ListView
        android:id="@+id/cfg_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:background="@color/white"
        android:divider="@color/list_divider"
        android:dividerHeight="1dp" />

    <EditText
        android:id="@+id/cfg_edit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@color/bg_edit"
        android:hint="@string/ai_apikey"
        android:inputType="text"
        android:padding="8dp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_yes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="@color/bg_button"
            android:text="@string/confirm"
            android:textColor="@color/white"
            android:visibility="gone" />

        <Space
            android:layout_width="8dp"
            android:layout_height="match_parent" />

        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="@color/bg_button_cancel2"
            android:text="@string/cancel"
            android:textColor="@color/white" />
    </LinearLayout>
</LinearLayout>
